# =============================================================================
# ImageDataCore — Docker Compose Environment
# Copy this to .env and adjust if needed. These defaults use Docker service
# names and are ready for `docker-compose up`.
# For local (non-Docker) development, change hostnames to localhost.
# =============================================================================

# PostgreSQL
POSTGRES_PASSWORD=imagedata

# MinIO (S3-compatible)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ImageDataCore Backend
# Use "postgres" (Docker service name) for Docker, "localhost" for local dev
DATABASE_URL=postgresql+asyncpg://imagedata:imagedata@postgres:5432/imagedata_db
# Use "minio" (Docker service name) for Docker, "localhost:9000" for local dev
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=imagedata
S3_REGION=us-east-1
LABEL_TOOL_BASE_URL=http://host.docker.internal:8004
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8005
NEXT_PUBLIC_LABEL_TOOL_URL=http://localhost:8004

# Preprocessing Worker (Docker 2)
# URL where the worker can reach ImageDataCore backend (for webhook callbacks)
BACKEND_CALLBACK_URL=http://host.docker.internal:8005
# URL where the backend can reach the worker (for dispatching jobs)
PREPROCESSING_WORKER_URL=http://host.docker.internal:8000
